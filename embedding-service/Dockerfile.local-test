# ─── Local Test Dockerfile ────────────────────────────────────────────────────
# Simpler single-stage build for local testing.
# Does NOT pre-download the model (downloads on first request — slower first call).
# Use the main Dockerfile for production.

FROM python:3.12-slim

WORKDIR /app

# Install uv for fast dependency resolution
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

# Copy and install requirements
COPY requirements.txt .
RUN uv pip install --system --no-cache-dir -r requirements.txt

# Copy source code
COPY src/ ./src/

# Default env vars
ENV MODEL_NAME="BAAI/bge-small-en-v1.5" \
    LANCE_DB_PATH="/tmp/familytv_vectors" \
    PORT=8080 \
    HOST=0.0.0.0 \
    LOG_LEVEL=info \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1

EXPOSE 8080

CMD ["uvicorn", "src.main:app", "--host", "0.0.0.0", "--port", "8080"]
